PORT=3000
# JWT_SECRET — chave que assina as sessões. Para o login único (SSO) com o
# Moura One funcionar, este valor PRECISA ser IDÊNTICO ao configurado no
# Moura One (lá ele aparece como RSVP_JWT_SECRET). Use um valor longo e secreto.
JWT_SECRET=
DATA_DIR=/app/data
ADMIN_EMAIL=admin@moura.com.br
# Senha da conta-mestre. DEIXE EM BRANCO e o sistema gera uma senha forte e
# aleatória no primeiro boot (mostrada UMA vez no log). Ou defina uma senha
# forte aqui. NUNCA use uma senha simples/conhecida.
ADMIN_PASSWORD=
ADMIN_NAME=Administrador
BASE_URL=https://moura-rsvp-production.up.railway.app
