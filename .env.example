PORT=3000
# ── Criptografia de dados pessoais em repouso (AES-256-GCM) ──────────────────
# Chave de 256 bits em hexadecimal (64 caracteres). SEM ela, os dados ficam em
# claro (compatível com instalações existentes — defina e rode a migração para
# cifrar os registros já existentes).
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DATA_ENCRYPTION_KEY=
# JWT_SECRET — chave que assina as sessões. Para o login único (SSO) com o
# Moura One funcionar, este valor PRECISA ser IDÊNTICO ao configurado no
# Moura One (lá ele aparece como RSVP_JWT_SECRET). Use um valor longo e secreto.
JWT_SECRET=
DATA_DIR=/app/data
ADMIN_EMAIL=admin@moura.com.br
# Senha da conta-mestre. DEIXE EM BRANCO e o sistema gera uma senha forte e
# aleatória no primeiro boot (mostrada UMA vez no log). Ou defina uma senha
# forte aqui. NUNCA use uma senha simples/conhecida.
ADMIN_PASSWORD=
ADMIN_NAME=Administrador
BASE_URL=https://moura-rsvp-production.up.railway.app

# ── Backup automático (snapshot SQLite + uploads → storage externo) ───────────
# Sem as variáveis S3_*, o backup roda só local (no mesmo volume do Railway —
# NÃO protege contra perda do volume). Configure o Cloudflare R2 para proteção real.
#   R2: crie um bucket, gere um API Token (S3) e use o endpoint do R2.
S3_BUCKET=moura-backups
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
BACKUP_PREFIX=rsvp-backups/
# Intervalo do job automático em horas (padrão 24; 0 desliga).
BACKUP_INTERVAL_HOURS=24
# Quantos snapshots locais manter (padrão 7).
BACKUP_KEEP=7
# Chave para cron externo (POST /api/backup/cron?key=X).
# Gere com: node -e "console.log(require('crypto').randomUUID())"
BACKUP_CRON_KEY=
